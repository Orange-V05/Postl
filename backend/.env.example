# Postl Backend Production Environment Variables
# Copy to .env and fill in with your real keys

# Server Configuration
PORT=4000
ALLOWED_ORIGINS=https://your-frontend-url.com

# AI Engine Connectivity
OPENROUTER_API_KEY=your_openrouter_api_key
AI_SERVER_URL=https://your-ai-server-url.com

# Firebase Admin Configuration (JSON String)
FIREBASE_SERVICE_ACCOUNT_KEY='{"type": "service_account", "project_id": "postl-0", ...}'
