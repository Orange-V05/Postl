    "autoprefixer": "^10.4.21",
    "cypress": "^15.13.0",
    "esbuild": "^0.27.4",
    "jest": "^30.3.0",
    "jest-axe": "^10.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "terser": "^5.46.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.2"
  },
  "browserslist": {
